<!--   ***********Exhaust************ -->

<animation>
  <type>textranslate</type>
  <object-name>draken_exhaust</object-name>
  <property>engines/engine[0]/n1</property>
  <interpolation>
     <entry><ind>0.0</ind><dep>0.0</dep></entry>
     <entry><ind>29</ind><dep>0.0</dep></entry>
     <entry><ind>30</ind><dep>-0.5</dep></entry>
     <entry><ind>100</ind><dep>-0.5</dep></entry>
  </interpolation>
  <axis>
   <x>1</x>
   <y>0</y>
  </axis>
 </animation>

 <animation>
  <type>material</type>
  <object-name>draken_exhaust</object-name>
  <condition>
   <greater-than>
    <property>engines/engine[0]/n1</property>
    <value>29</value>
   </greater-than>
  </condition>
  <emission>
   <red>0.008</red>
   <green>0.003</green>
   <blue>0.003</blue>
   <factor-prop>engines/engine[0]/n1</factor-prop>
  </emission>
 </animation>

