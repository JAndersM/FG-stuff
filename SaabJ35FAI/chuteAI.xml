<?xml version="1.0"?>
<PropertyList>

    <path>chute.ac</path>
    <nopreview/>

  <animation>
    <type>select</type>
    <object-name>chute</object-name>
    <object-name>rope</object-name>
    <condition>
      <property>sim/multiplay/generic/int[0]</property>
    </condition>
 </animation>

 <animation>
   <type>rotate</type>
   <object-name>chute</object-name>
   <object-name>rope</object-name>
   <property>sim/multiplay/generic/float[1]</property>
   <factor>-1</factor>
   <condition>
       <property>sim/multiplay/generic/int[0]</property>
   </condition>
   <center>
     <x-m>0</x-m>
     <y-m>0</y-m>
     <z-m>0</z-m>
   </center>
   <axis>
     <x>0</x>
     <y>1</y>
     <z>0</z>
   </axis>
 </animation>

 <animation>
   <type>rotate</type>
   <object-name>chute</object-name>
   <object-name>rope</object-name>
   <property>sim/multiplay/generic/float[2]</property>
   <factor>-1</factor>
   <condition>
     <property>sim/multiplay/generic/int[0]</property>
   </condition>
   <center>
     <x-m>0</x-m>
     <y-m>0</y-m>
     <z-m>0</z-m>
   </center>
   <axis>
     <x>0</x>
     <y>0</y>
     <z>1</z>
   </axis>
 </animation>

</PropertyList>

