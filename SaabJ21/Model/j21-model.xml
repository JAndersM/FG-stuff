<!-- ***** Propeller ***** -->
	
<animation>
		<type>spin</type>
		<object-name>Spinner</object-name>
		<object-name>Propeller</object-name>
		<property>engines/engine/rpm</property>
		<factor>0.68</factor>
		<axis>
     <object-name>Propaxis</object-name>
		</axis>
	</animation>

	<animation>
		<type>select</type>
		<object-name>Propeller</object-name>
		<condition>
			<less-than>
				<property>engines/engine[0]/rpm</property>
				<value>1200</value>
			</less-than>
		</condition>
	</animation>

	<animation>
		<type>select</type>
		<object-name>Prop_disk</object-name>
		<condition>
			<greater-than>
				<property>engines/engine[0]/rpm</property>
				<value>1200</value>
			</greater-than>
		</condition>
	</animation>

